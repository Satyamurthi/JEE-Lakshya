<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application night theme styled with web platform branding. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_indigo</item>
        <item name="colorPrimaryVariant">@color/primary_indigo_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_violet</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color matching web header. -->
        <item name="android:statusBarColor">@color/bg_slate_dark</item>
        <item name="android:windowBackground">@color/bg_slate_dark</item>
    </style>
</resources>